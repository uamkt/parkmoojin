---
import Base from "./Base.astro";
import EntityHead from "../components/EntityHead.astro";
import QuickAnswerBox from "../components/QuickAnswerBox.astro";
import FAQSection from "../components/FAQSection.astro";
import CategoryBadge from "../components/CategoryBadge.astro";
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
  buildOrganizationSchema,
} from "../lib/schema";
import { ORGANIZATION } from "../lib/entities";
import type { ArticleCategory } from "../content.config";

interface Props {
  title: string;
  description: string;
  category: ArticleCategory;
  publishedAt: Date;
  updatedAt?: Date;
  author: string;
  tags: string[];
  ogImage?: string;
  language: "ko" | "en";
  quickAnswer: string;
  faq?: { question: string; answer: string }[];
  citations?: { title: string; url: string; publishedYear?: number }[];
  doi?: string;
  isbn?: string;
  slug: string;
}

const props = Astro.props;
const canonical = `https://uamkt.com/articles/${props.slug}`;

const schemas: Record<string, unknown>[] = [
  buildOrganizationSchema(ORGANIZATION),
  buildArticleSchema({
    title: props.title,
    description: props.description,
    publishedAt: props.publishedAt,
    updatedAt: props.updatedAt,
    author: props.author,
    url: canonical,
    ogImage: props.ogImage,
  }),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "Articles", url: "https://uamkt.com/articles" },
    { name: props.category, url: `https://uamkt.com/articles/category/${props.category}` },
    { name: props.title, url: canonical },
  ]),
];
if (props.faq && props.faq.length > 0) {
  schemas.push(buildFAQSchema(props.faq));
}

const dateStr = props.publishedAt.toISOString().slice(0, 10);
---
<Base
  title={`${props.title} | UAM KoreaTech Articles`}
  description={props.description}
  canonical={canonical}
  ogImage={props.ogImage}
>
  <EntityHead schemas={schemas} slot="head" />

  <article class="max-w-3xl mx-auto px-4 py-8" data-pagefind-body>
    <header class="mb-8 border-b border-gray-200 pb-6">
      <CategoryBadge category={props.category} />
      <h1 class="text-3xl md:text-4xl font-bold mt-4 mb-3" style="color: var(--color-navy);">
        {props.title}
      </h1>
      <p class="text-lg text-gray-700 mb-4">{props.description}</p>
      <div class="flex flex-wrap gap-3 text-sm text-gray-500">
        <span>{dateStr}</span>
        <span>·</span>
        <span>{props.author}</span>
        {props.language === "en" && <><span>·</span><span class="font-mono">EN</span></>}
        {props.tags.map((tag) => (
          <span class="px-2 py-0.5 bg-gray-100 rounded text-xs font-mono">#{tag}</span>
        ))}
      </div>
    </header>

    <QuickAnswerBox question={props.title}>
      {props.quickAnswer}
    </QuickAnswerBox>

    <div class="prose prose-lg max-w-none article-content">
      <slot />
    </div>

    {props.faq && props.faq.length > 0 && (
      <FAQSection items={props.faq} />
    )}

    {props.citations && props.citations.length > 0 && (
      <section class="citations mt-12 border-t border-gray-200 pt-6">
        <h2 class="text-lg font-bold mb-3">Citations</h2>
        <ol class="list-decimal list-inside text-sm space-y-2 text-gray-700">
          {props.citations.map((c) => (
            <li>
              <a href={c.url} class="underline hover:opacity-70" target="_blank" rel="noopener">
                {c.title}
              </a>
              {c.publishedYear && <span class="text-gray-500"> ({c.publishedYear})</span>}
            </li>
          ))}
        </ol>
      </section>
    )}

    {(props.doi || props.isbn) && (
      <section class="meta mt-6 text-xs text-gray-500 font-mono">
        {props.doi && <div>DOI: {props.doi}</div>}
        {props.isbn && <div>ISBN: {props.isbn}</div>}
      </section>
    )}
  </article>
</Base>

<style is:global>
  .article-content h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .article-content h3 {
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .article-content p {
    margin: 0.75rem 0;
    line-height: 1.75;
  }
  .article-content ul, .article-content ol {
    padding-left: 1.5rem;
    margin: 0.75rem 0;
  }
  .article-content ul { list-style: disc; }
  .article-content ol { list-style: decimal; }
  .article-content li { margin: 0.25rem 0; }
  .article-content a { text-decoration: underline; }
  .article-content a:hover { opacity: 0.7; }
  .article-content code {
    background-color: #f3f4f6;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }
  .article-content table {
    display: block;
    overflow-x: auto;
    white-space: nowrap;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.95em;
  }
  .article-content th, .article-content td {
    border: 1px solid #e5e7eb;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .article-content th {
    background-color: #f9fafb;
    font-weight: 600;
  }
  .article-content pre {
    background-color: #0a1628;
    color: #f3f4f6;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1rem 0;
  }
  .article-content pre code {
    background-color: transparent;
    padding: 0;
    color: inherit;
  }
  .article-content blockquote {
    border-left: 4px solid var(--color-gold);
    padding-left: 1rem;
    color: #4b5563;
    font-style: italic;
    margin: 1rem 0;
  }
</style>
