---
import { CATEGORY_META, type ArticleCategory } from "../content.config";
interface Props {
  category: ArticleCategory;
}
const { category } = Astro.props;
const meta = CATEGORY_META[category];
---
<a href={`/articles/category/${category}`}
   class="inline-block px-3 py-1 rounded-full text-xs font-mono uppercase tracking-wider hover:opacity-80"
   style="background-color: var(--color-gold-soft); color: var(--color-navy);">
  {category} <span class="ml-1 opacity-70">— {meta.ko}</span>
</a>
