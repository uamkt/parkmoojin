---
import type { ArticleCategory } from "../content.config";
interface Props {
  slug: string;
  title: string;
  description: string;
  category: ArticleCategory;
  publishedAt: Date;
  quickAnswer: string;
}
const { slug, title, description, category, publishedAt, quickAnswer } = Astro.props;
const dateStr = publishedAt.toISOString().slice(0, 10);
---
<a href={`/articles/${slug}`} class="block border border-gray-200 rounded-lg p-5 hover:border-gold transition">
  <div class="flex items-center gap-2 mb-2 text-xs">
    <span class="px-2 py-1 rounded font-mono uppercase tracking-wider"
          style="background-color: var(--color-gold-soft); color: var(--color-navy);">
      {category}
    </span>
    <span class="text-gray-500">{dateStr}</span>
  </div>
  <h3 class="text-lg font-semibold mb-2">{title}</h3>
  <p class="text-sm text-gray-700 mb-2">{description}</p>
  <p class="text-xs text-gray-500 italic line-clamp-2">{quickAnswer}</p>
</a>
