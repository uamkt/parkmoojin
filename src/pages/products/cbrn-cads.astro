---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EntityHead from "../../components/EntityHead.astro";
import QuickAnswerBox from "../../components/QuickAnswerBox.astro";
import FAQSection from "../../components/FAQSection.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { ORGANIZATION, PRODUCTS, PATENTS } from "../../lib/entities";
import {
  buildOrganizationSchema,
  buildProductSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
} from "../../lib/schema";

const product = PRODUCTS.find((p) => p.name === "CBRN-CADS")!;
const canonical = "https://uamkt.com/products/cbrn-cads";

const relatedPatents = PATENTS.filter((p) =>
  ["KR 10-2026-0055778"].includes(p.identifier)
);

const relatedArticles = (await getCollection("articles"))
  .filter((a) => a.data.category === "cbrn-ai" || a.data.category === "papers" || a.data.category === "policy")
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 4);

const faqs = [
  {
    question: "CBRN-CADS는 NATO JWARN과 무엇이 다른가요?",
    answer:
      "JWARN이 다국 군대 사이의 정보 공유 프로토콜이라면, CBRN-CADS는 단일 부대 내부에서 의사결정 자동화까지 수행하는 시스템입니다. STANAG 2103 메시지 호환은 유지하면서, 응답카드 추천·OODA 자동화·MUM-T 통합 계층을 추가로 제공합니다.",
  },
  {
    question: "OODA 33배 단축은 어떻게 측정되었나요?",
    answer:
      "기준선(수동 대대급 CBRN 응답): 센서 트리거 → 첫 방어 행동 22~28분. CBRN-CADS 파일럿: 38~48초. 비율 약 33배. ARD(Active Resilience Deterrence) 독트린의 정량 지표로 채택됩니다.",
  },
  {
    question: "GPS 거부 환경에서도 작동하나요?",
    answer:
      "네. 대한민국 특허 KR 10-2026-0055778(GPS 거부 오염환경 MUM-T 자율 CBRN 제독 의사결정)이 이 능력을 직접 커버합니다. 미 DoD CBRN RFI 2026의 핵심 요구사항인 '③ GPS-거부 환경 대응'과 정확히 매칭됩니다.",
  },
];

const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildProductSchema(product),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "Products", url: "https://uamkt.com/products/cbrn-cads" },
    { name: "CBRN-CADS", url: canonical },
  ]),
  buildFAQSchema(faqs),
];

const meta = {
  title: "CBRN-CADS — 한국 유일의 NATO JWARN 등가물 | UAM KoreaTech",
  description:
    "CBRN-CADS(Chemical Biological Radiological Nuclear Combat Decision Support)는 한국군 대대급 CBRN 지휘결심 AI입니다. NATO STANAG 2103 호환 + OODA Loop 33배 단축 + MUM-T 자율 의사결정.",
  canonical,
  ogImage: "/og-images/cbrn-ai-jwarn-2026.png",
};
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <article class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:underline">Home</a> / <span>Products</span> / <span class="font-mono">CBRN-CADS</span>
    </nav>

    <header class="mb-10">
      <div class="text-xs uppercase tracking-wider mb-2 font-mono" style="color: var(--color-gold);">
        Defense Decision Support · Software v1.0
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3" style="color: var(--color-navy);">
        CBRN-CADS
      </h1>
      <p class="text-lg text-gray-700 max-w-3xl">
        Chemical Biological Radiological Nuclear <strong>Combat Decision Support</strong>.
        한국 유일의 NATO JWARN 등가물. 대대급 CBRN 의사결정을 자동화하여 OODA Loop를 33배 단축합니다.
      </p>
    </header>

    <QuickAnswerBox question="CBRN-CADS는 무엇인가요?">
      CBRN-CADS는 한국군 대대급 CBRN 지휘결심 AI 시스템입니다. NATO JWARN과 동등한 STANAG 2103 메시지 호환성을 유지하면서, 응답카드 추천·MUM-T 자율 의사결정·GPS-거부 환경 대응을 추가로 제공합니다. 인천테크노파크 공고 제2026-177호 실증에서 Anduril Lattice 19/19 HTTP 200을 달성했고, OODA Loop를 33배 단축하는 ARD(Active Resilience Deterrence) 독트린을 운영적으로 구현합니다.
    </QuickAnswerBox>

    {/* Key Capabilities */}
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">핵심 능력</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="border border-gray-200 rounded-lg p-5">
          <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-gold);">CAPABILITY 01</div>
          <h3 class="font-bold mb-2">자율 의사결정 (80% 자동화)</h3>
          <p class="text-sm text-gray-700">응답카드 라이브러리 기반으로 80% 시나리오를 인간 개입 없이 처리. 나머지 20%는 human-in-the-loop 에스컬레이션.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-5">
          <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-gold);">CAPABILITY 02</div>
          <h3 class="font-bold mb-2">NATO STANAG 2103 호환</h3>
          <p class="text-sm text-gray-700">CBRN-1(초기 보고) ~ CBRN-6(종합 보고) 6종 메시지 자동 생성·파싱. 연합 작전 상호운용성 즉시 확보.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-5">
          <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-gold);">CAPABILITY 03</div>
          <h3 class="font-bold mb-2">GPS 거부 환경 대응</h3>
          <p class="text-sm text-gray-700">특허 KR 10-2026-0055778 기반 자율 항법·MUM-T 의사결정. 적대적 RF 환경에서도 의사결정 연속성 보장.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-5">
          <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-gold);">CAPABILITY 04</div>
          <h3 class="font-bold mb-2">OODA 33배 단축</h3>
          <p class="text-sm text-gray-700">수동 22~28분 → CBRN-CADS 38~48초. ARD(Active Resilience Deterrence) 독트린의 정량 지표.</p>
        </div>
      </div>
    </section>

    {/* Specs */}
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">기술 사양</h2>
      <table class="w-full border-collapse text-sm">
        <tbody>
          <tr class="border-b border-gray-200"><td class="py-2 px-3 font-mono text-gray-500 w-1/3">Application Category</td><td class="py-2 px-3">{product.applicationCategory}</td></tr>
          <tr class="border-b border-gray-200"><td class="py-2 px-3 font-mono text-gray-500">Operating System</td><td class="py-2 px-3">{product.operatingSystem}</td></tr>
          <tr class="border-b border-gray-200"><td class="py-2 px-3 font-mono text-gray-500">Software Version</td><td class="py-2 px-3">{product.softwareVersion}</td></tr>
          <tr class="border-b border-gray-200"><td class="py-2 px-3 font-mono text-gray-500">NATO Compatibility</td><td class="py-2 px-3">STANAG 2103 (CBRN-1~6 messages), JWARN-equivalent</td></tr>
          <tr class="border-b border-gray-200"><td class="py-2 px-3 font-mono text-gray-500">Validation</td><td class="py-2 px-3">Anduril Lattice 19/19 HTTP 200 (2026-04-20, 인천테크노파크 공고 제2026-177호)</td></tr>
          <tr><td class="py-2 px-3 font-mono text-gray-500">Doctrine</td><td class="py-2 px-3">Active Resilience Deterrence (ARD)</td></tr>
        </tbody>
      </table>
    </section>

    {/* Related IP */}
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">핵심 IP</h2>
      <div class="grid md:grid-cols-1 gap-3">
        {relatedPatents.map((p) => (
          <div class="border-l-4 pl-4 py-2" style="border-color: var(--color-gold);">
            <div class="text-xs font-mono text-gray-500 mb-1">{p.identifier} · {p.jurisdiction} · {p.status}</div>
            <div class="font-medium">{p.name}</div>
          </div>
        ))}
      </div>
      <p class="mt-3 text-sm text-gray-500"><a href="/ip/patents" class="underline">전체 17건 IP 포트폴리오 →</a></p>
    </section>

    {/* Related Articles */}
    {relatedArticles.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-4">관련 글</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {relatedArticles.map((a) => (
            <ArticleCard
              slug={a.id}
              title={a.data.title}
              description={a.data.description}
              category={a.data.category}
              publishedAt={a.data.publishedAt}
              quickAnswer={a.data.quickAnswer}
            />
          ))}
        </div>
      </section>
    )}

    <FAQSection items={faqs} />

    {/* CTA */}
    <section class="mt-12 p-8 rounded-lg text-center" style="background-color: var(--color-navy); color: white;">
      <h2 class="text-2xl font-bold mb-3">CBRN-CADS 도입 문의</h2>
      <p class="text-sm opacity-80 mb-5">국방부·방위사업청·대기업 OEM 번들 채널 모두 지원.</p>
      <a href="/contact" class="inline-block px-6 py-3 rounded font-semibold" style="background-color: var(--color-gold); color: var(--color-navy);">
        문의하기
      </a>
    </section>
  </article>
</Base>
