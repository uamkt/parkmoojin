---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EntityHead from "../../components/EntityHead.astro";
import QuickAnswerBox from "../../components/QuickAnswerBox.astro";
import FAQSection from "../../components/FAQSection.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { ORGANIZATION, PRODUCTS, PATENTS } from "../../lib/entities";
import {
  buildOrganizationSchema,
  buildProductSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
} from "../../lib/schema";

const product = PRODUCTS.find((p) => p.name === "BLIS-D")!;
const canonical = "https://uamkt.com/products/blis-d";

const relatedPatents = PATENTS.filter((p) =>
  ["KR 10-2026-0046421", "US 19/568,797", "KR 10-2026-0055778"].includes(p.identifier)
);

const relatedArticles = (await getCollection("articles"))
  .filter((a) => ["cbrn-ai", "policy", "papers"].includes(a.data.category))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const faqs = [
  {
    question: "BLIS-D는 기존 습식 제독과 무엇이 다른가요?",
    answer:
      "기존 습식 제독은 물·세제·중화제를 사용하여 부피·중량이 크고 폐수 처리가 필요합니다. BLIS-D는 블리드에어 기반 오존·플라즈마·자외선·열 분해를 결합한 건식(dry) 하이브리드 방식으로, 폐수 미발생·드론 적재 가능·GPS 거부 환경에서도 운용 가능합니다.",
  },
  {
    question: "어떤 IP가 BLIS-D를 보호하나요?",
    answer:
      "한국 출원 KR 10-2026-0046421 + 미국 PCT US 19/568,797(블리드에어 하이브리드 건식 제독) + KR 10-2026-0055778(GPS 거부 MUM-T 자율 제독 의사결정) 3건의 출원특허가 코어를 보호합니다. 모두 자체 출원 9건 포트폴리오의 일부입니다.",
  },
  {
    question: "CBRN-CADS와 어떻게 연동되나요?",
    answer:
      "CBRN-CADS가 위험구역(GEO_TYPE_CONTROL_AREA)을 식별하면, BLIS-D 드론에 자율 제독 임무를 자동 배정합니다. MUM-T(유·무인 복합) 환경에서 인간 의사결정 없이 80% 시나리오 자동 처리가 가능합니다.",
  },
];

const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildProductSchema(product),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "Products", url: "https://uamkt.com/products/blis-d" },
    { name: "BLIS-D", url: canonical },
  ]),
  buildFAQSchema(faqs),
];

const meta = {
  title: "BLIS-D — 블리드에어 하이브리드 건식 제독 드론 | UAM KoreaTech",
  description:
    "BLIS-D(BLISTER Drone Anti-Decontamination System)는 블리드에어 기반 오존·플라즈마·자외선·열 분해 건식 제독 드론입니다. 폐수 미발생·MUM-T 자율 운용·KR+US PCT 보호.",
  canonical,
  ogImage: "/og-default.png",
};
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <article class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:underline">Home</a> / <span>Products</span> / <span class="font-mono">BLIS-D</span>
    </nav>

    <header class="mb-10">
      <div class="text-xs uppercase tracking-wider mb-2 font-mono" style="color: var(--color-gold);">
        Decontamination · Embedded v1.0
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3" style="color: var(--color-navy);">
        BLIS-D
      </h1>
      <p class="text-lg text-gray-700 max-w-3xl">
        BLISTER Drone Anti-Decontamination System.
        블리드에어 기반 오존·플라즈마·자외선·열 분해 하이브리드 건식 제독 드론. 폐수 미발생, MUM-T 자율 의사결정 통합.
      </p>
    </header>

    <QuickAnswerBox question="BLIS-D는 무엇인가요?">
      BLIS-D는 항공기 블리드에어를 활용해 오존·플라즈마·자외선·열 분해 4단계로 화학·생물학적 오염 물질을 건식 분해하는 드론 통합 시스템입니다. 한국 출원 KR 10-2026-0046421과 미국 PCT US 19/568,797로 보호되며, CBRN-CADS의 자율 제독 의사결정(KR 10-2026-0055778)과 연동되어 GPS 거부 MUM-T 환경에서도 자율 임무 수행이 가능합니다.
    </QuickAnswerBox>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">핵심 능력</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="border border-gray-200 rounded-lg p-5">
          <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-gold);">CAPABILITY 01</div>
          <h3 class="font-bold mb-2">하이브리드 건식 분해</h3>
          <p class="text-sm text-gray-700">오존 + 플라즈마 + 자외선 + 열 분해 4단계 직렬화. 폐수·중화제 사용 없음.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-5">
          <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-gold);">CAPABILITY 02</div>
          <h3 class="font-bold mb-2">블리드에어 동력</h3>
          <p class="text-sm text-gray-700">드론 추진계의 블리드에어를 작동 유체로 재활용. 페이로드 효율 향상.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-5">
          <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-gold);">CAPABILITY 03</div>
          <h3 class="font-bold mb-2">MUM-T 자율 운용</h3>
          <p class="text-sm text-gray-700">CBRN-CADS의 응답카드와 연동되어 인간 개입 없이 임무 배정·실행·복귀까지 자동화.</p>
        </div>
        <div class="border border-gray-200 rounded-lg p-5">
          <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-gold);">CAPABILITY 04</div>
          <h3 class="font-bold mb-2">KR + US PCT 보호</h3>
          <p class="text-sm text-gray-700">한국·미국 동시 출원으로 K-방산 수출 패키지에서 IP 리스크 최소화.</p>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">기술 사양</h2>
      <table class="w-full border-collapse text-sm">
        <tbody>
          <tr class="border-b border-gray-200"><td class="py-2 px-3 font-mono text-gray-500 w-1/3">Application Category</td><td class="py-2 px-3">{product.applicationCategory}</td></tr>
          <tr class="border-b border-gray-200"><td class="py-2 px-3 font-mono text-gray-500">Operating System</td><td class="py-2 px-3">{product.operatingSystem}</td></tr>
          <tr class="border-b border-gray-200"><td class="py-2 px-3 font-mono text-gray-500">분해 방식</td><td class="py-2 px-3">오존 + 플라즈마 + 자외선 + 열 (4-stage hybrid dry)</td></tr>
          <tr class="border-b border-gray-200"><td class="py-2 px-3 font-mono text-gray-500">동력</td><td class="py-2 px-3">블리드에어 (Bleed Air)</td></tr>
          <tr><td class="py-2 px-3 font-mono text-gray-500">CBRN-CADS 통합</td><td class="py-2 px-3">예 — 응답카드 라이브러리 연동</td></tr>
        </tbody>
      </table>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-4">관련 IP</h2>
      <div class="grid gap-3">
        {relatedPatents.map((p) => (
          <div class="border-l-4 pl-4 py-2" style="border-color: var(--color-gold);">
            <div class="text-xs font-mono text-gray-500 mb-1">{p.identifier} · {p.jurisdiction} · {p.status}</div>
            <div class="font-medium">{p.name}</div>
          </div>
        ))}
      </div>
      <p class="mt-3 text-sm text-gray-500"><a href="/ip/patents" class="underline">전체 17건 IP 포트폴리오 →</a></p>
    </section>

    {relatedArticles.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-4">관련 글</h2>
        <div class="grid md:grid-cols-2 gap-4">
          {relatedArticles.map((a) => (
            <ArticleCard
              slug={a.id}
              title={a.data.title}
              description={a.data.description}
              category={a.data.category}
              publishedAt={a.data.publishedAt}
              quickAnswer={a.data.quickAnswer}
            />
          ))}
        </div>
      </section>
    )}

    <FAQSection items={faqs} />

    <section class="mt-12 p-8 rounded-lg text-center" style="background-color: var(--color-navy); color: white;">
      <h2 class="text-2xl font-bold mb-3">BLIS-D 도입 문의</h2>
      <p class="text-sm opacity-80 mb-5">국방·민방위·산업 안전 영역 모두 적용 가능.</p>
      <a href="/contact" class="inline-block px-6 py-3 rounded font-semibold" style="background-color: var(--color-gold); color: var(--color-navy);">
        문의하기
      </a>
    </section>
  </article>
</Base>
