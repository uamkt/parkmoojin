---
import Base from "../layouts/Base.astro";
import EntityHead from "../components/EntityHead.astro";
import { ORGANIZATION } from "../lib/entities";
import { buildOrganizationSchema, buildBreadcrumbSchema } from "../lib/schema";

const canonical = "https://uamkt.com/vertiport";

const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "버티포트", url: canonical },
  ]),
];

const meta = {
  title: "버티포트 · 인천공항 UAM 버티포트 2027-2028 | UAM KoreaTech",
  description:
    "유에이엠코리아텍이 주목하는 한국 버티포트 인프라 — 인천국제공항 UAM 버티포트(2027-2028 준공), KINTEX-김포공항 corridor, 여의도 floating hub. 섬에어·본에어·인천국제공항공사와의 협업 로드맵.",
  canonical,
};

// 박 대표 핵심 제휴 파트너 (사전 노출용)
const PARTNERS = [
  {
    name: "섬에어",
    role: "프로펠러 항공",
    detail: "김포-사천 노선 2026년 런칭 — 단거리 도서·지방 항공 모델",
    status: "2026 운항 시작",
    accent: "#4ad6b5",
  },
  {
    name: "본에어",
    role: "헬리콥터 운항",
    detail: "잠실 ↔ 인천국제공항 헬기 노선 — 도심 ↔ 공항 직결 모빌리티",
    status: "운항 중",
    accent: "#c9a449",
  },
  {
    name: "인천국제공항 UAM 버티포트",
    role: "공항 통합 vertiport",
    detail: "2027-2028 준공 및 운행 예정 — 한국 최초 국제공항 직결 UAM hub",
    status: "2027-2028 준공",
    accent: "#0a1628",
  },
];

// 버티포트 5대 핵심 인프라
const COMPONENTS = [
  {
    n: "01",
    name: "인천국제공항 UAM 버티포트",
    desc: "RKSI 직결 vertiport, 국제선 환승객 도심 직접 연결 (2027-2028 준공)",
  },
  {
    n: "02",
    name: "KINTEX-김포공항 corridor",
    desc: "Hyundai Supernal 주관, 한국 최초 도심권 상용 corridor (2026 시연)",
  },
  {
    n: "03",
    name: "여의도 floating hub",
    desc: "Korean Air 종합 UAM 시스템, 한강변 floating hotel + vertiport (2028)",
  },
  {
    n: "04",
    name: "잠실-인천공항 헬기 노선",
    desc: "본에어 운영, 헬기→UAM 전환 단계의 검증된 도심·공항 직결 모델",
  },
  {
    n: "05",
    name: "김포-사천 프로펠러 노선",
    desc: "섬에어 2026 런칭, 단거리 지방·도서 항공 — 향후 eVTOL 확장 시 기준점",
  },
];
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <article class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:underline">Home</a> / <span class="font-mono">버티포트</span>
    </nav>

    <header class="mb-10 rounded-lg p-6 md:p-10" style="background-color: #f5ecd6; border-left: 6px solid #c9a449;">
      <div class="text-xs uppercase tracking-wider mb-2 font-mono" style="color: #c9a449;">
        메인 카테고리 · UAM Infrastructure
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3" style="color: #0a1628;">
        버티포트
      </h1>
      <p class="text-xl text-gray-800 mb-3">
        한국 UAM 시대를 여는 5대 핵심 vertiport 인프라
      </p>
      <p class="text-base text-gray-700 leading-relaxed max-w-3xl">
        인천국제공항 UAM 버티포트(2027-2028 준공), KINTEX-김포공항 corridor, 여의도 floating hub.
        유에이엠코리아텍은 섬에어·본에어·인천국제공항공사와의 협업을 통해
        한국 UAM 운영의 안전·운항·인프라 reference architecture 를 선점한다.
      </p>
    </header>

    {/* 5대 핵심 인프라 */}
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5" style="color: #0a1628;">5 Core Vertiport Infrastructure</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {COMPONENTS.map((c) => (
          <div class="block border-2 rounded-lg p-5 hover:opacity-90 transition"
               style="border-color: #c9a449;">
            <div class="text-[10px] uppercase tracking-wider font-mono mb-1 font-bold"
                 style="color: #c9a449;">
              {c.n}
            </div>
            <h3 class="font-bold mb-2 leading-snug" style="color: #0a1628;">{c.name}</h3>
            <p class="text-sm text-gray-700 leading-relaxed">{c.desc}</p>
          </div>
        ))}
      </div>
    </section>

    {/* 협업 파트너 */}
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5" style="color: #0a1628;">협업·제휴 파트너</h2>
      <div class="grid md:grid-cols-3 gap-4">
        {PARTNERS.map((p) => (
          <div class="border border-gray-200 rounded-lg p-5 hover:shadow-md transition">
            <div class="text-[10px] uppercase tracking-wider font-mono mb-1"
                 style={`color: ${p.accent};`}>
              {p.role}
            </div>
            <h3 class="text-lg font-bold mb-2" style="color: #0a1628;">{p.name}</h3>
            <p class="text-sm text-gray-700 leading-relaxed mb-3">{p.detail}</p>
            <div class="inline-block px-2 py-1 rounded text-[10px] font-mono"
                 style={`background-color: ${p.accent}1a; color: ${p.accent};`}>
              {p.status}
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* 콘텐츠 카테고리 link */}
    <section class="mb-12 p-6 rounded-lg" style="background-color: #f9fafb;">
      <h2 class="text-xl font-bold mb-3" style="color: #0a1628;">버티포트 콘텐츠</h2>
      <p class="text-sm text-gray-700 mb-4">
        버티포트 관련 시장 동향, 정책 분석, 케이스 스터디는 Articles 카테고리에서 확인하실 수 있습니다.
      </p>
      <div class="flex flex-wrap gap-2">
        <a href="/articles/category/vertiport"
           class="px-3 py-1.5 rounded text-sm border border-gray-300 hover:opacity-80 transition"
           style="color: #c9a449; border-color: #c9a449;">
          버티포트 카테고리 →
        </a>
        <a href="/articles/category/uam-korea"
           class="px-3 py-1.5 rounded text-sm border border-gray-300 hover:opacity-80 transition"
           style="color: #4ad6b5; border-color: #4ad6b5;">
          한국 UAM 시장 →
        </a>
        <a href="/articles/category/aerospace"
           class="px-3 py-1.5 rounded text-sm border border-gray-300 hover:opacity-80 transition"
           style="color: #0a1628; border-color: #0a1628;">
          항공우주 →
        </a>
        <a href="/articles/category/defense"
           class="px-3 py-1.5 rounded text-sm border border-gray-300 hover:opacity-80 transition"
           style="color: #0a1628; border-color: #0a1628;">
          방산 →
        </a>
      </div>
    </section>

    {/* Civil/Defense 문의 CTA */}
    <section class="mt-12 p-8 rounded-lg text-center" style="background-color: #f5ecd6;">
      <h2 class="text-xl font-bold mb-2" style="color: #0a1628;">버티포트·UAM 협업 문의</h2>
      <p class="text-sm text-gray-700 mb-4 max-w-2xl mx-auto">
        공항·도심 vertiport 인프라 도입, 안전 시스템(CBRN·조류충돌) 통합, UAM 운항 컨소시엄 참여를 검토 중이시면 연락 주세요.
      </p>
      <div class="flex flex-wrap gap-2 justify-center">
        <a href="/contact?track=civil"
           data-track-event="cta_civil_click" data-track-label="vertiport_page"
           class="inline-block px-6 py-3 rounded font-semibold transition hover:opacity-90"
           style="background-color: #c9a449; color: #0a1628;">
          Civil 트랙 문의 →
        </a>
        <a href="/contact?track=defense"
           data-track-event="cta_defense_click" data-track-label="vertiport_page"
           class="inline-block px-6 py-3 rounded font-semibold transition hover:opacity-90"
           style="background-color: #0a1628; color: #c9a449;">
          Defense 트랙 문의 →
        </a>
      </div>
    </section>
  </article>
</Base>
