---
import Base from "../layouts/Base.astro";
import EntityHead from "../components/EntityHead.astro";
import { ORGANIZATION, CONNECTED_SITES, APPS, IP_STATS, PATENTS } from "../lib/entities";
import { buildOrganizationSchema, buildBreadcrumbSchema } from "../lib/schema";

const canonical = "https://uamkt.com/digital-ecosystem";

// V2.3 §D-3 — Digital Ecosystem 진열
// Web 2 (uamkt.com 자체 제외)
const sites = CONNECTED_SITES.filter((s) => s.url !== "https://uamkt.com/");

// V2.3 §D-3 메인 진열용 Apps 4개 + Coming Soon 1개. Bird Strike + TacticalPrompt 제외.
const PRIMARY_APP_NAMES = new Set([
  "CBRN Tactical",
  "AVIX-AI",
  "BLIS-D",
  "CBRN-CADS",
  "K-UAM",
  "근접항공제독지원 CADS",
]);
const visibleApps = APPS.filter((a) => PRIMARY_APP_NAMES.has(a.name));

const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "Digital Ecosystem", url: canonical },
  ]),
];

const meta = {
  title: "Digital Portfolio · 유에이엠코리아텍 고유 IP | UAM KoreaTech",
  description: `UAM KoreaTech 디지털 포트폴리오 — Intellectual Property ${IP_STATS.total}건 · Connected Sites · iOS Apps.`,
  canonical,
};

const grantedPatents = PATENTS.filter((p) => p.status === "granted");
const pendingPatents = PATENTS.filter((p) => p.status === "pending");
const transferredPatents = PATENTS.filter((p) => p.status === "transferred-in");

const trackBg = {
  Civil: "var(--color-teal-soft)",
  Defense: "var(--color-gold-soft)",
  Dual: "#e8eef5",
  ESG: "#e0f5e8",
};
const trackColor = {
  Civil: "var(--color-teal)",
  Defense: "var(--color-gold)",
  Dual: "var(--color-navy)",
  ESG: "#0a7a35",
};
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <article class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:underline">Home</a> / <span class="font-mono">Digital Ecosystem</span>
    </nav>

    <header class="mb-10">
      <div class="text-xs uppercase tracking-wider mb-2 font-mono" style="color: var(--color-gold);">Digital Portfolio</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3" style="color: var(--color-navy);">
        유에이엠코리아텍 고유 IP
      </h1>
      <p class="text-lg text-gray-700 leading-relaxed max-w-3xl">
        UAM KoreaTech의 디지털 포트폴리오 — Intellectual Property <strong>{IP_STATS.total}건</strong>,
        Connected Sites <strong>{sites.length}개</strong>, iOS Apps <strong>{visibleApps.length}종</strong>.
        도서 진열은 <a href="/publications" class="underline" style="color: var(--color-gold);">/publications</a>에서 확인.
      </p>
    </header>

    {/* Intellectual Property — V2.3 사용자 수정: Digital Portfolio 최상단 */}
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-4" style="color: var(--color-navy);">Intellectual Property ({IP_STATS.total}건)</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <a href="/ip/patents" class="block border-2 rounded-lg p-5 text-center hover:opacity-90 transition" style="border-color: var(--color-gold);">
          <div class="text-3xl md:text-4xl font-bold" style="color: var(--color-gold);">{IP_STATS.granted}</div>
          <div class="text-xs font-mono uppercase tracking-wider mt-1 text-gray-600">자체 등록 특허</div>
        </a>
        <a href="/ip/patents" class="block border-2 rounded-lg p-5 text-center hover:opacity-90 transition" style="border-color: var(--color-teal);">
          <div class="text-3xl md:text-4xl font-bold" style="color: var(--color-teal);">{IP_STATS.pending}</div>
          <div class="text-xs font-mono uppercase tracking-wider mt-1 text-gray-600">자체 출원 특허</div>
        </a>
        <a href="/ip/patents" class="block border-2 rounded-lg p-5 text-center hover:opacity-90 transition border-gray-300">
          <div class="text-3xl md:text-4xl font-bold" style="color: var(--color-navy);">{IP_STATS.transferredIn}</div>
          <div class="text-xs font-mono uppercase tracking-wider mt-1 text-gray-600">기술이전 특허</div>
        </a>
        <a href="/ip/patents" class="block border-2 rounded-lg p-5 text-center hover:opacity-90 transition border-gray-300">
          <div class="text-3xl md:text-4xl font-bold" style="color: var(--color-navy);">{IP_STATS.trademarkPending}</div>
          <div class="text-xs font-mono uppercase tracking-wider mt-1 text-gray-600">출원 상표</div>
        </a>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <div>
          <h3 class="text-sm font-bold mb-2 font-mono uppercase tracking-wider" style="color: var(--color-gold);">등록 ({grantedPatents.length})</h3>
          <ul class="space-y-2">
            {grantedPatents.slice(0, 4).map((p) => (
              <li class="border border-gray-200 rounded p-2 text-xs">
                <div class="font-mono text-[10px] text-gray-500">{p.identifier}</div>
                <div class="font-medium leading-snug">{p.name}</div>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-bold mb-2 font-mono uppercase tracking-wider" style="color: var(--color-teal);">출원 ({pendingPatents.length})</h3>
          <ul class="space-y-2">
            {pendingPatents.slice(0, 4).map((p) => (
              <li class="border border-gray-200 rounded p-2 text-xs">
                <div class="font-mono text-[10px] text-gray-500">{p.identifier} · {p.jurisdiction}</div>
                <div class="font-medium leading-snug">{p.name}</div>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-bold mb-2 font-mono uppercase tracking-wider" style="color: var(--color-navy);">기술이전 ({transferredPatents.length})</h3>
          <ul class="space-y-2">
            {transferredPatents.map((p) => (
              <li class="border border-gray-200 rounded p-2 text-xs">
                <div class="font-mono text-[10px] text-gray-500">{p.identifier} · {(p as { transferredFrom?: string }).transferredFrom}</div>
                <div class="font-medium leading-snug">{p.name}</div>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <p class="text-xs text-gray-600 leading-relaxed mt-4">
        ★ 박무진 대표 <strong>단독 1저자 9건</strong> 포함 · KIPRIS · USPTO · CNIPA 검증 가능 ·
        SK텔레콤 · 삼성전자 · 포스코 기술이전 3건.
        <a href="/ip/patents" class="underline font-mono ml-1" style="color: var(--color-gold);">전체 17건 IP 포트폴리오 →</a>
      </p>
    </section>

    <section class="mb-12">
      <h2 class="text-xl font-bold mb-4" style="color: var(--color-navy);">Connected Sites ({sites.length})</h2>
      <div class="grid md:grid-cols-2 gap-3">
        {sites.map((s) => (
          <a href={s.url} target="_blank" rel="noopener"
             data-track-event="site_external_click" data-track-label={s.name}
             class={`block border-2 rounded-lg p-5 hover:opacity-90 transition ${s.highlight ? '' : 'border-gray-200'}`}
             style={s.highlight ? "border-color: var(--color-gold); background-color: var(--color-gold-soft);" : ""}>
            <div class="text-[10px] uppercase font-mono tracking-wider mb-1"
                 style={s.highlight ? "color: var(--color-gold);" : "color: #6b7280;"}>
              {s.type}{s.highlight ? " · ★ Core" : ""}
            </div>
            <div class="font-bold mb-1" style="color: var(--color-navy);">{s.name}</div>
            <div class="font-mono text-[11px] text-gray-500">{s.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</div>
            {s.note && <p class="text-xs text-gray-600 mt-2 leading-snug">{s.note}</p>}
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-xl font-bold mb-4" style="color: var(--color-navy);">iOS Applications ({visibleApps.length})</h2>
      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-3">
        {visibleApps.map((a) => {
          const statusBg = {
            "Available": "background-color: var(--color-gold); color: var(--color-navy);",
            "Coming Soon": "background-color: #6b7280; color: white;",
            "In Review": "background-color: #1d4ed8; color: white;",
          };
          return (
            <article class="border border-gray-200 rounded-lg p-4">
              <div class="flex items-center gap-2 mb-2 flex-wrap">
                <span class="text-[10px] font-mono uppercase tracking-wider px-2 py-0.5 rounded font-bold"
                      style={statusBg[a.status]}>{a.status}</span>
                <span class="text-[10px] font-mono uppercase px-2 py-0.5 rounded"
                      style={`background-color: ${trackBg[a.track]}; color: ${trackColor[a.track]};`}>{a.track}</span>
                <span class="text-[10px] text-gray-500 font-mono">{a.version}</span>
              </div>
              <h3 class="font-bold mb-1 leading-snug" style="color: var(--color-navy);">{a.name}</h3>
              <p class="text-xs text-gray-700 leading-relaxed">{a.role}</p>
              {a.eta && <p class="text-[10px] text-gray-500 font-mono mt-2">ETA {a.eta}</p>}
            </article>
          );
        })}
      </div>
      <p class="text-[11px] text-gray-500 mt-3 leading-relaxed">
        ※ App Store Connect 등록 8종 중 메인 진열용 6종. Bird Strike + TacticalPrompt 앱은 재제작 진행으로 본 페이지에서 제외 (V2.3 §D-3).
      </p>
    </section>
  </article>
</Base>
