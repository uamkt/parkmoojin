---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import EntityHead from "../../components/EntityHead.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import { CATEGORY_META, ARTICLE_CATEGORY_LIST, type ArticleCategory } from "../../content.config";
import { ORGANIZATION } from "../../lib/entities";
import { buildOrganizationSchema, buildBreadcrumbSchema } from "../../lib/schema";

const articles = (await getCollection("articles")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

// V2.4 (2026-05-18) — 박 대표 사업 전략 키워드 4 카테고리 추가
// 모든 ARTICLE_CATEGORY_LIST 키를 Record 에 명시해야 TS 빌드 통과
const articlesByCategory: Record<ArticleCategory, typeof articles> = {
  "market-trends": [],
  papers: [],
  "business-models": [],
  "cbrn-ai": [],
  policy: [],
  "case-studies": [],
  vertiport: [],
  "uam-korea": [],
  aerospace: [],
  defense: [],
};
for (const a of articles) {
  articlesByCategory[a.data.category].push(a);
}

const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "Articles", url: "https://uamkt.com/articles" },
  ]),
];

const meta = {
  title: "Articles | UAM KoreaTech — 버티포트 · 한국 UAM · 항공우주 · 방산 · CBRN AI",
  description:
    "유에이엠코리아텍 Articles 10개 카테고리: 버티포트(인천공항 UAM 2027-2028), 한국 UAM 시장(섬에어·본에어), 항공우주, 방산, 시장 동향 리포트, 미니 논문, 사업 모델, CBRN AI 전술 분석, 정책 분석, 케이스 스터디.",
  canonical: "https://uamkt.com/articles",
};
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <section class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="text-3xl md:text-4xl font-bold mb-2" style="color: var(--color-navy);">Articles</h1>
    <p class="text-gray-700 mb-8">총 {articles.length}개 글 · {ARTICLE_CATEGORY_LIST.length}개 카테고리</p>

    {/* 카테고리 인덱스 */}
    <nav class="grid md:grid-cols-3 gap-3 mb-12">
      {ARTICLE_CATEGORY_LIST.map((cat) => (
        <a href={`/articles/category/${cat}`}
           class="border border-gray-200 rounded-lg p-4 hover:border-gold transition">
          <div class="text-xs uppercase tracking-wider text-gray-500 mb-1 font-mono">{cat}</div>
          <div class="font-semibold">{CATEGORY_META[cat].ko}</div>
          <div class="text-xs text-gray-500 mt-1">{articlesByCategory[cat].length}건</div>
        </a>
      ))}
    </nav>

    {/* 최근 글 */}
    <h2 class="text-2xl font-bold mb-4">Latest Articles</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {articles.map((a) => (
        <ArticleCard
          slug={a.id}
          title={a.data.title}
          description={a.data.description}
          category={a.data.category}
          publishedAt={a.data.publishedAt}
          quickAnswer={a.data.quickAnswer}
        />
      ))}
    </div>
  </section>
</Base>
