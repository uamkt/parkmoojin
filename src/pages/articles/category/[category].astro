---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import EntityHead from "../../../components/EntityHead.astro";
import ArticleCard from "../../../components/ArticleCard.astro";
import {
  ARTICLE_CATEGORY_LIST,
  CATEGORY_META,
  type ArticleCategory,
} from "../../../content.config";
import { ORGANIZATION } from "../../../lib/entities";
import { buildOrganizationSchema, buildBreadcrumbSchema } from "../../../lib/schema";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return ARTICLE_CATEGORY_LIST.map((category) => {
    const filtered = articles
      .filter((a) => a.data.category === category)
      .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
    return {
      params: { category },
      props: { category, articles: filtered },
    };
  });
}

interface Props {
  category: ArticleCategory;
  articles: Awaited<ReturnType<typeof getCollection<"articles">>>;
}
const { category, articles } = Astro.props;
const cmeta = CATEGORY_META[category];
const canonical = `https://uamkt.com/articles/category/${category}`;

const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "Articles", url: "https://uamkt.com/articles" },
    { name: category, url: canonical },
  ]),
];

const meta = {
  title: `${cmeta.ko} (${category}) | UAM KoreaTech Articles`,
  description: cmeta.description,
  canonical,
};
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <section class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/articles" class="hover:underline">Articles</a> / <span class="font-mono">{category}</span>
    </nav>
    <h1 class="text-3xl md:text-4xl font-bold mb-2" style="color: var(--color-navy);">
      {cmeta.ko}
    </h1>
    <p class="text-gray-700 mb-8">{cmeta.description} · 총 {articles.length}건</p>

    {articles.length === 0 ? (
      <p class="text-gray-500 italic">아직 작성된 글이 없습니다.</p>
    ) : (
      <div class="grid md:grid-cols-2 gap-4">
        {articles.map((a) => (
          <ArticleCard
            slug={a.id}
            title={a.data.title}
            description={a.data.description}
            category={a.data.category}
            publishedAt={a.data.publishedAt}
            quickAnswer={a.data.quickAnswer}
          />
        ))}
      </div>
    )}
  </section>
</Base>
