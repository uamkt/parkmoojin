---
import Base from "../layouts/Base.astro";
import EntityHead from "../components/EntityHead.astro";
import { ORGANIZATION, FOUNDER } from "../lib/entities";
import {
  buildOrganizationSchema,
  buildPersonSchema,
  buildBreadcrumbSchema,
} from "../lib/schema";

const canonical = "https://uamkt.com/contact";

const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildPersonSchema(FOUNDER),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "Contact", url: canonical },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: "Contact UAM KoreaTech",
    url: canonical,
    mainEntity: { "@id": `${ORGANIZATION.url}#organization` },
  },
];

const meta = {
  title: "Contact | UAM KoreaTech (유에이엠코리아텍)",
  description:
    "UAM KoreaTech 문의처. CBRN-CADS·AVIX-AI·BLIS-D·TacticalPrompt 도입 및 협업 문의는 ceo@uamkt.com 또는 +82-2-795-2024로 연락주십시오.",
  canonical,
};
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <article class="max-w-3xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:underline">Home</a> / <span class="font-mono">Contact</span>
    </nav>

    <header class="mb-8">
      {/* V2.3 §D-5: Body 워딩 전체 삭제. 슬로건 + 트랙 CTA 아이콘만 유지. */}
      <h1 class="text-4xl md:text-5xl font-bold mb-3" style="color: var(--color-navy);">대표가 직접 응답합니다</h1>
      <div class="grid sm:grid-cols-2 gap-3" id="track-cta">
        <a id="cta-civil"
           href={`mailto:${ORGANIZATION.email}?subject=${encodeURIComponent('[Civil] 도입 문의 — ')}&body=${encodeURIComponent('대상 기관:\n검토 단계:\n예상 일정:\n\n자유 질의:')}`}
           data-track-event="cta_civil_click" data-track-label="contact_page_civil"
           class="block rounded-lg p-5 transition hover:opacity-90"
           style="background-color: var(--color-teal-soft); border: 2px solid var(--color-teal);">
          <div class="text-xs font-mono uppercase tracking-wider mb-1 font-bold" style="color: var(--color-teal);">Civil Track</div>
          <div class="font-bold flex items-center gap-2" style="color: var(--color-navy);">
            <span aria-hidden="true">🛬</span> Civil 트랙 문의 →
          </div>
        </a>
        <a id="cta-defense"
           href={`mailto:${ORGANIZATION.email}?subject=${encodeURIComponent('[Defense] R&D 협력 문의 — ')}&body=${encodeURIComponent('소속 기관:\n협력 형태 (R&D / Procurement / Joint):\n관심 제품 (BLIS-D / CBRN-CADS / AVIX-AI V3):\n\n자유 질의:')}`}
           data-track-event="cta_defense_click" data-track-label="contact_page_defense"
           class="block rounded-lg p-5 transition hover:opacity-90"
           style="background-color: var(--color-gold-soft); border: 2px solid var(--color-gold);">
          <div class="text-xs font-mono uppercase tracking-wider mb-1 font-bold" style="color: var(--color-gold);">Defense Track</div>
          <div class="font-bold flex items-center gap-2" style="color: var(--color-navy);">
            <span aria-hidden="true">🛡️</span> Defense 트랙 문의 →
          </div>
        </a>
      </div>
    </header>

    <script is:inline>
      // Highlight CTA based on ?track= query
      (function () {
        const params = new URLSearchParams(window.location.search);
        const track = params.get('track');
        if (track === 'civil') {
          const el = document.getElementById('cta-civil');
          if (el) { el.style.boxShadow = '0 0 0 4px var(--color-teal)'; el.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
        } else if (track === 'defense') {
          const el = document.getElementById('cta-defense');
          if (el) { el.style.boxShadow = '0 0 0 4px var(--color-gold)'; el.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
        }
      })();
    </script>

    {/* Primary card */}
    <section class="border-2 rounded-lg p-6 mb-8" style="border-color: var(--color-gold);">
      <h2 class="text-xl font-bold mb-4" style="color: var(--color-navy);">{ORGANIZATION.legalName}</h2>
      <dl class="grid sm:grid-cols-3 gap-y-3 text-sm">
        <dt class="font-mono uppercase text-xs text-gray-500 tracking-wider">Email</dt>
        <dd class="sm:col-span-2"><a href={`mailto:${ORGANIZATION.email}`} class="underline">{ORGANIZATION.email}</a></dd>

        <dt class="font-mono uppercase text-xs text-gray-500 tracking-wider">Mobile</dt>
        <dd class="sm:col-span-2"><a href={`tel:${ORGANIZATION.telephone}`} class="underline">{ORGANIZATION.telephone}</a></dd>

        <dt class="font-mono uppercase text-xs text-gray-500 tracking-wider">Office</dt>
        <dd class="sm:col-span-2"><a href={`tel:${ORGANIZATION.contactPoint[0].telephone}`} class="underline">{ORGANIZATION.contactPoint[0].telephone}</a></dd>

        <dt class="font-mono uppercase text-xs text-gray-500 tracking-wider">Address</dt>
        <dd class="sm:col-span-2">{ORGANIZATION.address.addressLocality}, {ORGANIZATION.address.addressCountry}</dd>

        <dt class="font-mono uppercase text-xs text-gray-500 tracking-wider">Founded</dt>
        <dd class="sm:col-span-2">{ORGANIZATION.foundingDate} · 직원 {ORGANIZATION.numberOfEmployees.value}명</dd>

        <dt class="font-mono uppercase text-xs text-gray-500 tracking-wider">Languages</dt>
        <dd class="sm:col-span-2">{ORGANIZATION.contactPoint[0].availableLanguage.join(" · ")}</dd>
      </dl>
    </section>

    {/* Founder card */}
    <section class="border border-gray-200 rounded-lg p-6 mb-8">
      <h2 class="text-xl font-bold mb-1" style="color: var(--color-navy);">{FOUNDER.name} · CEO</h2>
      <p class="text-sm text-gray-500 mb-4 font-mono">{FOUNDER.alternateName.join(" · ")}</p>
      <p class="text-sm text-gray-700 mb-4">{FOUNDER.description}</p>
      <div class="flex flex-wrap gap-3 text-sm">
        {FOUNDER.sameAs.map((url) => (
          <a href={url} target="_blank" rel="noopener" class="underline text-gray-700 hover:opacity-70">
            {url.replace(/^https?:\/\//, "")}
          </a>
        ))}
      </div>
    </section>

    {/* Inquiry routing */}
    <section class="mb-8">
      <h2 class="text-2xl font-bold mb-4" style="color: var(--color-navy);">문의 라우팅 가이드</h2>
      <div class="space-y-3 text-sm">
        <div class="border-l-4 pl-4 py-2" style="border-color: var(--color-gold);">
          <strong>제품 도입 (정부·군·대기업)</strong> — ceo@uamkt.com / 제목에 [도입] 명시. 24시간 내 1차 응답.
        </div>
        <div class="border-l-4 pl-4 py-2" style="border-color: var(--color-gold);">
          <strong>TacticalPrompt 컨설팅</strong> — ceo@uamkt.com / 제목에 [TPE] 명시. 도메인 인터뷰 일정 제안.
        </div>
        <div class="border-l-4 pl-4 py-2" style="border-color: var(--color-gold);">
          <strong>NATO/Anduril 파트너십</strong> — ceo@uamkt.com / 제목에 [Partner] 명시.
        </div>
        <div class="border-l-4 pl-4 py-2" style="border-color: var(--color-gold);">
          <strong>언론·기고</strong> — ceo@uamkt.com / 제목에 [Media] 명시.
        </div>
        <div class="border-l-4 pl-4 py-2" style="border-color: var(--color-gold);">
          <strong>채용</strong> — ceo@uamkt.com / 제목에 [Hire] 명시. 기술개발연구원·BD 포지션 상시 검토.
        </div>
      </div>
    </section>

    {/* External links */}
    <section>
      <h2 class="text-2xl font-bold mb-4" style="color: var(--color-navy);">외부 채널</h2>
      <ul class="grid sm:grid-cols-2 gap-3 text-sm">
        {ORGANIZATION.sameAs.map((url) => (
          <li class="border border-gray-200 rounded-lg p-3">
            <a href={url} target="_blank" rel="noopener" class="underline">
              {url.replace(/^https?:\/\//, "")}
            </a>
          </li>
        ))}
      </ul>
    </section>
  </article>
</Base>
