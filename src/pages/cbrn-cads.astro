---
import Base from "../layouts/Base.astro";
import EntityHead from "../components/EntityHead.astro";
import { ORGANIZATION, PILLARS } from "../lib/entities";
import { buildOrganizationSchema, buildBreadcrumbSchema } from "../lib/schema";

const pillar = PILLARS.find((p) => p.id === "pillar-2")!;
const canonical = "https://uamkt.com/cbrn-cads";

const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: pillar.slogan, url: canonical },
  ]),
];

const meta = {
  title: `CBRN-CADS · ${pillar.slogan} | UAM KoreaTech`,
  description: pillar.summary,
  canonical,
};
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <article class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:underline">Home</a> / <span class="font-mono">{pillar.slogan}</span>
    </nav>

    <header class="mb-10 rounded-lg p-6 md:p-10" style={`background-color: ${pillar.accentSoft}; border-left: 6px solid ${pillar.accent};`}>
      <div class="text-xs uppercase tracking-wider mb-2 font-mono" style={`color: ${pillar.accent};`}>
        Pillar 2 · Defense Track
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3" style="color: var(--color-navy);">
        CBRN-CADS · {pillar.slogan}
      </h1>
      <p class="text-xl text-gray-800 mb-3">{pillar.headline}</p>
      <p class="text-base text-gray-700 leading-relaxed max-w-3xl">{pillar.summary}</p>
    </header>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5" style="color: var(--color-navy);">5 Core Components</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {pillar.cards.map((c, i) => (
          <a href={c.href}
             class="block border-2 rounded-lg p-5 hover:opacity-90 transition"
             style={`border-color: ${pillar.accent};`}>
            <div class="text-[10px] uppercase tracking-wider font-mono mb-1 font-bold"
                 style={`color: ${pillar.accent};`}>
              {String(i + 1).padStart(2, "0")}
            </div>
            <h3 class="font-bold mb-2 leading-snug" style="color: var(--color-navy);">{c.name}</h3>
            <p class="text-sm text-gray-700 leading-relaxed">{c.desc}</p>
            <div class="text-xs font-mono mt-3 underline" style={`color: ${pillar.accent};`}>
              View detail →
            </div>
          </a>
        ))}
      </div>
    </section>

    {/* BOXO3 Detail Anchor */}
    <section id="boxo3" class="mb-12 border-l-4 pl-6 py-4" style="border-color: var(--color-teal);">
      <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-teal);">Source Technology</div>
      <h2 class="text-xl font-bold mb-2" style="color: var(--color-navy);">BOXO3 Hybrid Chamber — 스위스 40년 가스멸균 원천기술</h2>
      <p class="text-sm text-gray-700 leading-relaxed">
        스위스 BOX O3 AG와 <strong>LOI · Development AND Purchase Agreement</strong> 체결 완료. 40년 전통의 가스멸균
        시설 원천 기술을 한국 모빌리티 플랫폼(블리드에어 무인헬기)에 탑재하는 하이브리드 챔버 공동개발이
        진행 중입니다. 의료폐기물 활용 가스멸균 → CBRN 전장 제독으로 dual-use 적용.
      </p>
    </section>

    <section id="decision-ai" class="mb-12 border-l-4 pl-6 py-4" style="border-color: var(--color-gold);">
      <div class="text-xs uppercase tracking-wider font-mono mb-1" style="color: var(--color-gold);">Decision AI</div>
      <h2 class="text-xl font-bold mb-2" style="color: var(--color-navy);">CBRN 지휘결심 AI — Lattice 19/19 PoC</h2>
      <p class="text-sm text-gray-700 leading-relaxed">
        2026-04-20 인천테크노파크 공고 제2026-177호 <strong>Anduril Lattice 19/19 HTTP 200 실증</strong> 통과.
        OODA Loop 33× 압축 자율 의사결정 프로그램. NATO JWARN 등가물로 STANAG 2103 호환.
      </p>
    </section>

    <section class="mt-12 p-8 rounded-lg text-center" style={`background-color: ${pillar.accentSoft};`}>
      <h2 class="text-xl font-bold mb-2" style="color: var(--color-navy);">Defense·정부 R&D 협력 문의</h2>
      <a href="/contact?track=defense"
         data-track-event="cta_defense_click" data-track-label="cbrn_pillar_page"
         class="inline-block px-6 py-3 rounded font-semibold transition hover:opacity-90 mt-3"
         style={`background-color: ${pillar.accent}; color: var(--color-navy);`}>
        Defense 트랙 문의 →
      </a>
    </section>
  </article>
</Base>
