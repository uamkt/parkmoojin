---
import Base from "../../layouts/Base.astro";
import EntityHead from "../../components/EntityHead.astro";
import { ORGANIZATION, PATENTS, IP_STATS } from "../../lib/entities";
import {
  buildOrganizationSchema,
  buildBreadcrumbSchema,
  buildFAQSchema,
} from "../../lib/schema";

const canonical = "https://uamkt.com/ip/patents";

const granted = PATENTS.filter((p) => p.status === "granted");
const pending = PATENTS.filter((p) => p.status === "pending");
const transferred = PATENTS.filter((p) => p.status === "transferred-in");
const trademarks = PATENTS.filter((p) => p.status === "trademark-pending");

type PatentEntry = (typeof PATENTS)[number];

const STATUS_LABEL: Record<string, { ko: string; color: string }> = {
  granted: { ko: "등록", color: "#0a7a35" },
  pending: { ko: "출원", color: "#1d4ed8" },
  "transferred-in": { ko: "기술이전", color: "#b45309" },
  "trademark-pending": { ko: "상표 출원", color: "#7c3aed" },
};

const JURISDICTION_LABEL: Record<string, string> = {
  KR: "🇰🇷 한국",
  US: "🇺🇸 미국 (PCT)",
  CN: "🇨🇳 중국 (PCT)",
};

const faqs = [
  {
    question: "UAM KoreaTech의 IP 포트폴리오 규모는?",
    answer:
      `총 17건. 자체 등록특허 ${IP_STATS.granted}건, 자체 출원특허 ${IP_STATS.pending}건(KR 7 + US PCT 1 + CN PCT 1), 기술이전 특허 ${IP_STATS.transferredIn}건(SK텔레콤·삼성전자·POSCO), 출원 상표 ${IP_STATS.trademarkPending}건. 모든 항목은 KIPRIS·USPTO·CNIPA 공식 데이터베이스에서 조회 가능합니다.`,
  },
  {
    question: "기술이전 특허 3건은 어떻게 확보했나요?",
    answer:
      "SK텔레콤(멀티터치 디스플레이)·삼성전자(공기조화기)·POSCO(강재 피복 합성부재) 등 대기업으로부터 합법적 IP 인수를 통해 확보했습니다. 이는 CBRN-CADS·AVIX-AI 본업 IP와 별도로, K-방산 수출 패키지의 보조 자산으로 활용됩니다.",
  },
  {
    question: "가장 핵심적인 IP는 무엇인가요?",
    answer:
      "KR 10-2026-0055778 (GPS 거부 오염환경 MUM-T 자율 CBRN 제독 의사결정)이 CBRN-CADS의 핵심을 직접 보호합니다. 미 DoD CBRN RFI 2026의 4대 요구사항 중 ③(GPS-거부) + ④(MUM-T)와 정확히 매칭되어, 한국 기업으로서 매우 드문 차별화 영역을 형성합니다.",
  },
];

const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "IP", url: canonical },
  ]),
  buildFAQSchema(faqs),
  // ItemList of all 17 patents
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "UAM KoreaTech IP Portfolio",
    numberOfItems: PATENTS.length,
    itemListElement: PATENTS.map((p, i) => ({
      "@type": "ListItem",
      position: i + 1,
      item: { ...p, "@context": "https://schema.org" },
    })),
  },
];

const meta = {
  title: "IP 포트폴리오 17건 — 등록 4 · 출원 9 · 기술이전 3 · 상표 1 | UAM KoreaTech",
  description:
    "UAM KoreaTech의 17건 IP 포트폴리오: 자체 등록특허 4건, 출원특허 9건(KR 7 + US PCT 1 + CN PCT 1), 기술이전 3건(SK텔레콤·삼성전자·POSCO), 출원 상표 1건. KIPRIS·USPTO·CNIPA 검증.",
  canonical,
  ogImage: "/og-default.png",
};

const sections: { title: string; entries: readonly PatentEntry[]; help: string }[] = [
  { title: "자체 등록 특허 (4건)", entries: granted, help: "KIPRIS 등록 완료 — 직접 권리 행사 가능" },
  { title: "자체 출원 특허 (9건)", entries: pending, help: "심사 진행 중 (KR 7 + US PCT 1 + CN PCT 1)" },
  { title: "기술이전 특허 (3건)", entries: transferred, help: "대기업 IP 인수 — SK텔레콤·삼성전자·POSCO" },
  { title: "출원 상표 (1건)", entries: trademarks, help: "상표 출원 진행 중" },
];
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <article class="max-w-5xl mx-auto px-4 py-8">
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:underline">Home</a> / <span class="font-mono">IP</span>
    </nav>

    <header class="mb-10">
      <div class="text-xs uppercase tracking-wider mb-2 font-mono" style="color: var(--color-gold);">
        Intellectual Property Portfolio
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-3" style="color: var(--color-navy);">
        17건 IP 포트폴리오
      </h1>
      <p class="text-lg text-gray-700 max-w-3xl">
        자체 등록 4 · 자체 출원 9 · 기술이전 3 · 출원 상표 1.
        KIPRIS·USPTO·CNIPA 공식 데이터베이스에서 모든 항목 조회 가능.
      </p>
    </header>

    {/* Stats grid */}
    <section class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-12">
      <div class="border border-gray-200 rounded-lg p-4 text-center">
        <div class="text-3xl font-bold" style="color: var(--color-navy);">{IP_STATS.granted}</div>
        <div class="text-xs uppercase tracking-wider text-gray-500 mt-1">등록 특허</div>
      </div>
      <div class="border border-gray-200 rounded-lg p-4 text-center">
        <div class="text-3xl font-bold" style="color: var(--color-navy);">{IP_STATS.pending}</div>
        <div class="text-xs uppercase tracking-wider text-gray-500 mt-1">출원 특허</div>
      </div>
      <div class="border border-gray-200 rounded-lg p-4 text-center">
        <div class="text-3xl font-bold" style="color: var(--color-navy);">{IP_STATS.transferredIn}</div>
        <div class="text-xs uppercase tracking-wider text-gray-500 mt-1">기술이전</div>
      </div>
      <div class="border border-gray-200 rounded-lg p-4 text-center">
        <div class="text-3xl font-bold" style="color: var(--color-navy);">{IP_STATS.trademarkPending}</div>
        <div class="text-xs uppercase tracking-wider text-gray-500 mt-1">출원 상표</div>
      </div>
      <div class="rounded-lg p-4 text-center" style="background-color: var(--color-navy); color: white;">
        <div class="text-3xl font-bold" style="color: var(--color-gold);">{IP_STATS.total}</div>
        <div class="text-xs uppercase tracking-wider opacity-80 mt-1">전체</div>
      </div>
    </section>

    {/* Sections */}
    {sections.map((sec) => (
      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-1">{sec.title}</h2>
        <p class="text-sm text-gray-500 mb-4">{sec.help}</p>
        <div class="space-y-3">
          {sec.entries.map((p) => {
            const meta = STATUS_LABEL[p.status];
            const transferredFrom = "transferredFrom" in p ? p.transferredFrom : null;
            return (
              <article
                id={p["@id"].split("#").pop()}
                class="border border-gray-200 rounded-lg p-5 hover:border-gold transition"
              >
                <div class="flex flex-wrap items-center gap-2 text-xs mb-2">
                  <span
                    class="px-2 py-0.5 rounded font-mono uppercase tracking-wider text-white"
                    style={`background-color: ${meta.color};`}
                  >
                    {meta.ko}
                  </span>
                  <span class="font-mono text-gray-500">{p.identifier}</span>
                  <span class="text-gray-400">·</span>
                  <span class="text-gray-500">{JURISDICTION_LABEL[p.jurisdiction] ?? p.jurisdiction}</span>
                  <span class="text-gray-400">·</span>
                  <span class="text-gray-500">{p.datePublished}</span>
                  {transferredFrom && (
                    <>
                      <span class="text-gray-400">·</span>
                      <span class="text-gray-500">from {transferredFrom}</span>
                    </>
                  )}
                </div>
                <h3 class="font-semibold mb-2" style="color: var(--color-navy);">{p.name}</h3>
                <a href={p.url} target="_blank" rel="noopener" class="text-xs underline text-gray-500 hover:text-gray-700">
                  공식 데이터베이스에서 조회 →
                </a>
              </article>
            );
          })}
        </div>
      </section>
    ))}
  </article>
</Base>
