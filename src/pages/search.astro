---
/**
 * src/pages/search.astro — Pagefind static full-text search
 * 정의서 §13.4 Day 4 deliverable.
 *
 * Pagefind 인덱스는 `pagefind --site dist` 가 생성합니다 (postbuild).
 * 인덱스 산출물 경로: dist/pagefind/  →  배포 후 /pagefind/ 로 노출.
 * Article 레이아웃에 `data-pagefind-body` 표시되어 있어 articles만 인덱싱됩니다.
 */
import Base from "../layouts/Base.astro";
import EntityHead from "../components/EntityHead.astro";
import { ORGANIZATION } from "../lib/entities";
import { buildOrganizationSchema, buildBreadcrumbSchema } from "../lib/schema";

const canonical = "https://uamkt.com/search";
const schemas = [
  buildOrganizationSchema(ORGANIZATION),
  buildBreadcrumbSchema([
    { name: "Home", url: "https://uamkt.com/" },
    { name: "Search", url: canonical },
  ]),
];

const meta = {
  title: "Search | UAM KoreaTech",
  description: "유에이엠코리아텍 사이트 전체 검색. CBRN AI · 정책 · 케이스 스터디 · 미니 논문.",
  canonical,
};
---
<Base {...meta}>
  <EntityHead schemas={schemas} slot="head" />

  <section class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="text-3xl md:text-4xl font-bold mb-4" style="color: var(--color-navy);">
      Search
    </h1>
    <p class="text-gray-700 mb-6">
      전체 글에 대한 정적 풀텍스트 검색입니다. (Pagefind, 한국어 지원)
    </p>

    <div id="search"></div>
  </section>

  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" slot="head" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline define:vars={{}}>
    window.addEventListener("DOMContentLoaded", () => {
      if (typeof PagefindUI === "undefined") {
        const el = document.getElementById("search");
        if (el) el.innerHTML = "<p class='text-sm text-gray-500'>검색 인덱스가 로드되지 않았습니다. 빌드 후 정적 호스팅 환경에서 정상 동작합니다.</p>";
        return;
      }
      new PagefindUI({
        element: "#search",
        showImages: false,
        resetStyles: false,
        translations: {
          placeholder: "검색어를 입력하세요...",
          clear_search: "지우기",
          load_more: "더 보기",
          search_label: "검색",
          filters_label: "필터",
          zero_results: "[SEARCH_TERM] 에 대한 결과가 없습니다",
          many_results: "[SEARCH_TERM] 에 대한 [COUNT]개 결과",
          one_result: "[SEARCH_TERM] 에 대한 1개 결과",
          alt_search: "[SEARCH_TERM] 결과 없음. [DIFFERENT_TERM] 결과 표시:",
          search_suggestion: "결과 없음. 다음 검색어 시도: [DIFFERENT_TERM]",
          searching: "[SEARCH_TERM] 검색 중...",
        },
      });
    });
  </script>
</Base>
